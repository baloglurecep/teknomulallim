# Netlify Dashboard → Site settings → Environment variables
# Yerel test için .env dosyasına kopyalayın (netlify dev otomatik okur)

# MongoDB Atlas (free M0 cluster)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=teknomuallim

# Admin giriş — şifrenin SHA-256 hash'i (düz metin saklamayın)
# node -e "console.log(require('crypto').createHash('sha256').update('SIFRENIZ').digest('hex'))"
ADMIN_PASSWORD_HASH=c0d673208cc02d3f610a1f12769e8459760be769f5eb9a772dfb89cd35c0b9ee

# JWT imzalama (rastgele uzun bir string)
JWT_SECRET=degistirin-guclu-rastgele-bir-deger

# Cloudinary (Dashboard → Settings → Upload presets gerekmez, imzalı yükleme kullanılır)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Tek seferlik seed koruması (Atlas'a public/site-data.json aktarımı)
SEED_SECRET=degistirin-baska-bir-rastgele-deger

# İsteğe bağlı — frontend API kökü (varsayılan /api)
# VITE_API_BASE=/api
